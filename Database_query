FROM bookings;



-- 30. Average schedule fare
SELECT 
    AVG(fare) AS average_fare
FROM schedules;



-- 31. Highest fare
SELECT 
    MAX(fare) AS highest_fare
FROM schedules;



-- 32. Lowest fare
SELECT 
    MIN(fare) AS lowest_fare
FROM schedules;



-- 33. Bus count by type
SELECT 
    bus_type, 
    COUNT(*) AS total_buses
FROM buses
GROUP BY bus_type;



-- 34. Booking count by status
SELECT 
    booking_status, 
    COUNT(*) AS total_bookings
FROM bookings
