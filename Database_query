-- 36. Top routes with average fare more than 600
SELECT 
    r.source_city,
    r.destination_city,
    AVG(s.fare) AS average_fare
FROM schedules s
JOIN routes r ON s.route_id = r.route_id
GROUP BY r.route_id, r.source_city, r.destination_city
HAVING AVG(s.fare) > 600
ORDER BY average_fare DESC
LIMIT 3;



-- 37. Inner join booking details
SELECT 
    bk.booking_id,
    p.full_name AS passenger_name,
    p.phone,
    b.bus_name,
    r.source_city,
    r.destination_city,
    s.travel_date,
    bk.seat_number,
    bk.total_fare,
    bk.booking_status
FROM bookings bk
INNER JOIN passengers p ON bk.passenger_id = p.passenger_id
INNER JOIN schedules s ON bk.schedule_id = s.schedule_id
INNER JOIN buses b ON s.bus_id = b.bus_id
INNER JOIN routes r ON s.route_id = r.route_id;



-- 38. Left join passengers with booking count
SELECT 
    p.passenger_id,
    p.full_name,
    p.phone,
    COUNT(bk.booking_id) AS total_bookings
FROM passengers p
LEFT JOIN bookings bk ON p.passenger_id = bk.passenger_id
GROUP BY p.passenger_id, p.full_name, p.phone;



-- 39. Right join routes with schedules
SELECT 
    s.schedule_id,
    b.bus_name,
    r.source_city,
    r.destination_city,
    s.travel_date,
    s.fare
FROM schedules s
RIGHT JOIN routes r ON s.route_id = r.route_id
LEFT JOIN buses b ON s.bus_id = b.bus_id
ORDER BY r.route_id;



-- 40. Full outer join using union
SELECT 
    p.full_name AS passenger_name,
    bk.booking_id,
    bk.seat_number,
    bk.booking_status
FROM passengers p
LEFT JOIN bookings bk ON p.passenger_id = bk.passenger_id

UNION

SELECT 
    p.full_name AS passenger_name,
    bk.booking_id,
    bk.seat_number,
    bk.booking_status
FROM passengers p
RIGHT JOIN bookings bk ON p.passenger_id = bk.passenger_id;



-- 41. Cartesian product
SELECT 
    b.bus_name,
    r.source_city,
    r.destination_city
FROM buses b
CROSS JOIN routes r
LIMIT 20;



-- 42. Schedules above average fare
SELECT 
    schedule_id, 
    travel_date, 
    departure_time, 
    fare
FROM schedules
WHERE fare > (
    SELECT AVG(fare)
    FROM schedules
);



-- 43. Passengers who have bookings
SELECT 
    full_name, 
    phone
FROM passengers
WHERE passenger_id IN (
    SELECT passenger_id
    FROM bookings
);



-- 44. Fare above route average
SELECT 
    s.schedule_id, 
    s.route_id, 
    s.travel_date, 
    s.fare
FROM schedules s
WHERE s.fare > (
    SELECT AVG(s2.fare)
    FROM schedules s2
    WHERE s2.route_id = s.route_id
);



-- 45. Search buses Dhaka to Rangpur
SELECT 
    s.schedule_id,
    b.bus_name,
    b.bus_type,
    r.source_city,
    r.destination_city,
    s.travel_date,
    s.departure_time,
    s.arrival_time,
    s.fare,
    s.boarding_point,
    s.dropping_point
FROM schedules s
JOIN buses b ON s.bus_id = b.bus_id
JOIN routes r ON s.route_id = r.route_id
WHERE r.source_city = 'Dhaka'
AND r.destination_city = 'Rangpur'
AND s.travel_date = '2026-05-20';



-- 46. Seat availability
SELECT 
    s.schedule_id,
    b.bus_name,
    b.capacity,
    COUNT(bk.booking_id) AS booked_seats,
    b.capacity - COUNT(bk.booking_id) AS available_seats
FROM schedules s
JOIN buses b ON s.bus_id = b.bus_id
LEFT JOIN bookings bk 
    ON s.schedule_id = bk.schedule_id
    AND bk.booking_status = 'Booked'
GROUP BY s.schedule_id, b.bus_name, b.capacity;



--47. Booked seats for schedule 1
SELECT 
    bk.booking_id,
    p.full_name AS passenger_name,
    bk.seat_number,
    bk.booking_status
FROM bookings bk
JOIN passengers p ON bk.passenger_id = p.passenger_id
WHERE bk.schedule_id = 1
AND bk.booking_status = 'Booked';



--48. Search booking by phone
SELECT 
    bk.booking_id,
    p.full_name AS passenger_name,
    p.phone,
    b.bus_name,
    r.source_city,
    r.destination_city,
    s.travel_date,
    s.departure_time,
    bk.seat_number,
    bk.total_fare,
    bk.booking_status
FROM bookings bk
JOIN passengers p ON bk.passenger_id = p.passenger_id
JOIN schedules s ON bk.schedule_id = s.schedule_id
JOIN buses b ON s.bus_id = b.bus_id
JOIN routes r ON s.route_id = r.route_id
WHERE p.phone = '01712345678';



49. Fare category using case
SELECT 
    bk.booking_id,
    p.full_name,
    bk.total_fare,
    CASE
        WHEN bk.total_fare > 1000 THEN 'High Fare'
        WHEN bk.total_fare BETWEEN 500 AND 1000 THEN 'Medium Fare'
        ELSE 'Low Fare'
    END AS fare_category
FROM bookings bk
JOIN passengers p ON bk.passenger_id = p.passenger_id
ORDER BY bk.total_fare DESC;


 50. Fare ranking
SELECT 
    s.schedule_id,
    b.bus_name,
    r.source_city,
    r.destination_city,
    s.fare,
    DENSE_RANK() OVER (ORDER BY s.fare DESC) AS fare_rank
FROM schedules s
JOIN buses b ON s.bus_id = b.bus_id
JOIN routes r ON s.route_id = r.route_id;



51. Schedules between dates
SELECT 
    s.schedule_id,
    b.bus_name,
    r.source_city,
    r.destination_city,
    s.travel_date,
    s.departure_time,
    s.fare
FROM schedules s
JOIN buses b ON s.bus_id = b.bus_id
JOIN routes r ON s.route_id = r.route_id
WHERE s.travel_date BETWEEN '2026-05-20' AND '2026-05-22'
ORDER BY s.travel_date, s.departure_time;




 55. Admin dashboard summary
SELECT 
    (SELECT COUNT(*) FROM passengers) AS total_passengers,
    (SELECT COUNT(*) FROM buses) AS total_buses,
    (SELECT COUNT(*) FROM routes) AS total_routes,
    (SELECT COUNT(*) FROM schedules) AS total_schedules,
