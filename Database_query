56. Total revenue
SELECT 
    SUM(total_fare) AS total_revenue
FROM bookings
WHERE booking_status = 'Booked'
AND payment_status = 'Paid';



57. Route wise total schedules
SELECT 
    r.source_city,
    r.destination_city,
    COUNT(s.schedule_id) AS total_schedules
FROM routes r
LEFT JOIN schedules s ON r.route_id = s.route_id
GROUP BY r.route_id, r.source_city, r.destination_city
ORDER BY total_schedules DESC;



58. Bus wise total bookings
SELECT 
    b.bus_name,
    b.bus_type,
    COUNT(bk.booking_id) AS total_bookings
FROM buses b
JOIN schedules s ON b.bus_id = s.bus_id
LEFT JOIN bookings bk ON s.schedule_id = bk.schedule_id
GROUP BY b.bus_id, b.bus_name, b.bus_type
ORDER BY total_bookings DESC;