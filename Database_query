-- 15. Buses with capacity more than 40
SELECT 
    bus_name, 
    bus_type, 
    capacity
FROM buses
WHERE capacity > 40;



-- 16. Schedules with fare more than 800
SELECT 
    schedule_id, 
    travel_date, 
    departure_time, 
    fare
FROM schedules
WHERE fare > 800;



-- 17. AC buses with capacity 40 or more
SELECT 
    bus_name, 
    bus_type, 
    capacity
FROM buses
WHERE bus_type = 'AC'
AND capacity >= 40;



-- 18. Routes related to Dhaka
SELECT 
    source_city, 
    destination_city, 
    distance_km, 
    estimated_time
FROM routes
WHERE source_city = 'Dhaka'
OR destination_city = 'Dhaka';



-- 19. Buses except Non-AC
SELECT 
    bus_name, 
    bus_type, 
    capacity
FROM buses
WHERE bus_type != 'Non-AC';



-- 20. Fare between 500 and 1000
SELECT 
    schedule_id, 
    travel_date, 
    departure_time, 
    fare
FROM schedules
WHERE fare BETWEEN 500 AND 1000;



-- 21. Source city in Dhaka or Rangpur
SELECT 
    source_city, 
    destination_city, 
    distance_km
FROM routes
WHERE source_city IN ('Dhaka', 'Rangpur');



-- 22. Unique source cities
SELECT DISTINCT 
    source_city
FROM routes;



-- 23. Passenger name like Hasan
SELECT 
    passenger_id, 
    full_name, 
    phone, 
    email
FROM passengers
WHERE full_name LIKE '%Hasan%';



-- 24. Passengers with email
SELECT 
    full_name, 
    phone, 
    email
FROM passengers
WHERE email IS NOT NULL;



-- 25. Buses ordered by capacity
SELECT 
    bus_name, 
    bus_type, 
    capacity
FROM buses
ORDER BY capacity DESC;



-- 26. First five passengers
SELECT 
    passenger_id, 
    full_name, 
    phone
FROM passengers
LIMIT 5;



-- 27. Pagination passengers
SELECT 
    passenger_id, 
    full_name, 
    phone
FROM passengers
ORDER BY passenger_id
LIMIT 5 OFFSET 5;



-- 28. Total passengers
SELECT 
    COUNT(*) AS total_passengers
FROM passengers;



